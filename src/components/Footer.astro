---
import { SOCIAL_LINKS, COPYRIGHT_NAME } from "../consts";
import SocialIcon from "./SocialIcon.astro";

const today = new Date();
const builtAt = new Date();
const builtAtParts = new Intl.DateTimeFormat("zh-CN", {
  timeZone: "Asia/Shanghai",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
})
  .formatToParts(builtAt)
  .reduce<Record<string, string>>((acc, part) => {
    if (part.type !== "literal") {
      acc[part.type] = part.value;
    }
    return acc;
  }, {});
const builtAtShort = `${builtAtParts.year}-${builtAtParts.month}-${builtAtParts.day} ${builtAtParts.hour}:${builtAtParts.minute}`;
const builtAtFull = `${builtAtShort} UTC+08:00 (Asia/Shanghai)`;
---

<div class="site-footer-spacer" aria-hidden="true"></div>
<footer
  class="site-footer ui-surface-shell ui-surface-fixed-bottom"
  role="contentinfo"
>
  <div class="footer-inner ui-acrylic-strip">
    <div class="footer-meta">
      <p class="footer-line">
        <span
          >&copy; {today.getFullYear()}
          {COPYRIGHT_NAME}. All rights reserved.</span
        >
        <span class="build-info">Last updated at build: {builtAtFull}.</span>
      </p>
    </div>
    <div class="social-links">
      {
        SOCIAL_LINKS.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer">
            <span class="sr-only">{link.label}</span>
            <SocialIcon icon={link.icon} />
          </a>
        ))
      }
    </div>
  </div>
</footer>
<style>
  .site-footer-spacer {
    height: var(--surface-strip-sync-height, var(--surface-strip-min-height));
    transition: height 160ms ease;
  }

  .site-footer {
    z-index: 90;
  }

  .footer-inner {
    --surface-strip-pad-y: 0.6rem;
    --surface-strip-pad-x: 1rem;
    --surface-strip-pad-bottom-extra: 0px;
    --surface-strip-border-top: 1px solid var(--glass-border);
    --surface-strip-border-bottom: 0;
    --surface-strip-shadow: 0 -8px 20px rgba(0, 0, 0, 0.08);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    column-gap: var(--section-gap-x);
    row-gap: var(--gap-2xl);
    align-items: center;
    color: rgb(var(--gray));
    text-align: left;
  }
  .footer-meta {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--gap-md);
    text-align: left;
    line-height: 1.2;
  }
  .footer-meta p {
    margin: 0;
  }
  .footer-line {
    display: flex;
    align-items: baseline;
    gap: var(--gap-md);
    flex-wrap: wrap;
  }
  .build-info {
    font-size: 0.78rem;
    margin-top: 0;
  }
  .social-links {
    display: flex;
    justify-content: flex-end;
    gap: var(--gap-sm);
    margin-top: 0;
    flex-wrap: wrap;
  }
  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    text-decoration: none;
    color: rgb(var(--gray));
    border-radius: 999px;
  }
  .social-links a:hover {
    color: rgb(var(--gray-dark));
  }
  .social-links a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 430px) {
    .site-footer-spacer {
      height: var(--surface-strip-sync-height, var(--surface-strip-min-height));
    }

    .footer-inner {
      --surface-strip-pad-y: 0.5rem;
      --surface-strip-pad-x: 0.75rem;
      grid-template-columns: 1fr;
    }
    .build-info {
      font-size: 0.75rem;
    }
    .social-links {
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer-spacer {
      transition: none;
    }
  }
</style>
