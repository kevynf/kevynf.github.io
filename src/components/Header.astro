---
import { NAV_LINKS, SITE_TITLE } from "../consts";
import { withBase } from "../utils/withBase";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="site-header ui-surface-shell ui-surface-sticky-top">
  <div class="header-inner ui-acrylic-strip">
    <a class="brand" href={withBase("/")}>{SITE_TITLE}</a>

    <nav class="nav-links" aria-label="Primary navigation">
      {
        NAV_LINKS.map((link) => (
          <HeaderLink href={link.href} reserveText={link.label}>
            {link.label}
          </HeaderLink>
        ))
      }
    </nav>

    <div class="header-actions">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    z-index: 100;
  }

  .header-inner {
    --header-active-color: var(--accent);
    --surface-strip-pad-y: 0.6rem;
    --surface-strip-pad-x: 1rem;
    --surface-strip-pad-bottom-extra: 0px;
    --surface-strip-border-top: 0;
    --surface-strip-border-bottom: 1px solid var(--glass-border);
    --surface-strip-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    display: flex;
    align-items: center;
    gap: 0.9rem;
    min-width: 0;
  }

  .brand {
    color: rgb(var(--black));
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex: 0 0 auto;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
    flex-wrap: wrap;
  }

  .nav-links :global(a) {
    color: rgb(var(--gray-dark));
    font-size: 0.95rem;
    text-underline-offset: 0.2em;
  }

  .nav-links :global(a.active) {
    color: var(--accent);
  }

  .header-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0;
    flex: 0 0 auto;
  }

  .brand:focus-visible,
  .nav-links :global(a:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  @media (max-width: 860px) {
    .header-inner {
      --surface-strip-pad-y: 0.5rem;
      --surface-strip-pad-x: 0.75rem;
      flex-wrap: wrap;
      row-gap: 0.55rem;
    }

    .brand {
      margin-right: auto;
    }

    .nav-links {
      order: 3;
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 0.15rem;
      scrollbar-width: thin;
    }
  }

  @media (max-width: 430px) {
    .brand {
      font-size: 0.95rem;
    }
  }
</style>
